# APLOMB. — Facebook Page control credentials (example).
#
# Copy to scripts/.fb.env (gitignored) and fill in. Never commit the real file,
# never paste FB_PAGE_ACCESS_TOKEN into chat. scripts/fb-page.mjs reads these;
# process.env always wins over this file.

# The getaplomb.com Page id (Meta Business Settings → Pages → the Page → ID).
FB_PAGE_ID=

# A System User token (recommended — non-expiring) OR a long-lived Page token.
# Generate inside the controllable "Get Aplomb" portfolio (1183365767175630)
# with scopes: pages_manage_posts, pages_read_engagement, pages_show_list
# (+ pages_manage_engagement for comment moderation).
FB_PAGE_ACCESS_TOKEN=

# Optional. Defaults to v23.0 if unset.
FB_API_VERSION=v23.0

# FB_USER_TOKEN: a short-lived USER token from Graph API Explorer
# (developers.facebook.com/tools/explorer). This is the ONE step only you can
# do (it needs your Meta login). Click "Add a Permission" and include:
#   business_management, pages_show_list, pages_read_engagement,
#   pages_manage_posts, pages_manage_engagement
# then "Generate Access Token", approve, and paste it here (not into chat).
# Used by `discover` (resolve portfolio/Page ownership) and `bootstrap-token`
# (exchange → non-expiring Page token). FB_APP_ID/SECRET only needed by
# bootstrap-token and for whoami scope/expiry readout.
FB_APP_ID=
FB_APP_SECRET=
FB_USER_TOKEN=
