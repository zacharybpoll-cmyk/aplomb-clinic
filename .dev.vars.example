# Copy to `.dev.vars` for local `wrangler pages dev`. NEVER commit `.dev.vars`.
# In production these are set via Cloudflare Pages → Settings → Env vars.

# Stripe — start with test-mode keys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Price IDs (one per SKU × billing mode)
STRIPE_PRICE_SERUM_ONETIME=""
STRIPE_PRICE_SERUM_SUBSCRIPTION=""
STRIPE_PRICE_DAILY_ONETIME=""
STRIPE_PRICE_DAILY_SUBSCRIPTION=""
STRIPE_PRICE_ROOTS_ONETIME=""
STRIPE_PRICE_ROOTS_SUBSCRIPTION=""
STRIPE_PRICE_CALM_ONETIME=""
STRIPE_PRICE_CALM_SUBSCRIPTION=""
STRIPE_PRICE_BREATH_ONETIME=""
STRIPE_PRICE_BREATH_SUBSCRIPTION=""

# Supabase
SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_ANON_KEY=""

# Resend (transactional email + Broadcasts marketing)
RESEND_API_KEY="re_..."
EMAIL_FROM="APLOMB. <orders@getaplomb.com>"
EMAIL_FROM_MARKETING="APLOMB. <hello@getaplomb.com>"
EMAIL_BUSINESS_NAME="APLOMB."
EMAIL_BUSINESS_ADDRESS="[street, city, state, zip]"  # CAN-SPAM required; populate before launch
EMAIL_UNSUB_SECRET=""  # 32+ random bytes; HMAC for unsubscribe tokens
RESEND_AUDIENCE_ID=""  # Resend Broadcasts audience UUID

# Site
SITE_URL="https://getaplomb.com"

# Supabase Auth (for magic-link sessions)
SUPABASE_JWT_SECRET=""  # JWT secret from Supabase dashboard → Settings → API

# Cron auth
CRON_SHARED_SECRET=""  # any 32+ random bytes; required by /cron/* endpoints

# Cloudflare Turnstile (CAPTCHA on checkout)
TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Observability
SENTRY_DSN=""
PLAUSIBLE_SITE_ID=""

# Shipping
SHIPPING_FLAT_CENTS="799"
FREE_SHIPPING_THRESHOLD_CENTS="7500"
